{
  "name": "yt-pb-calc",
  "description": "See video duration for different playback speeds on YouTube.",
  "version": "3.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:ff": "wxt -b firefox",
    "build": "wxt build",
    "build:ff": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:ff": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "keywords": [
    "browser-extension",
    "youtube",
    "brave",
    "chromium",
    "firefox",
    "librewolf",
    "playback-speed",
    "video-duration",
    "productivity",
    "speed-watch",
    "time-management"
  ],
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@wxt-dev/auto-icons": "^1.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  },
  "author": "Shaikh Shafeen <shafeen@duck.com> (https://github.com/kurtnettle)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kurtnettle/yt-pb-calc.git"
  },
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.30.3"
}
